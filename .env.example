# Telnyx
TELNYX_API_KEY=                  # Bearer token for Telnyx REST API
TELNYX_PHONE_NUMBER=             # Default outbound caller ID; +E164
NEXT_PUBLIC_TELNYX_PHONE_NUMBER= # Same number, exposed to the browser

# Telnyx connection IDs — these are DIFFERENT things, keep both.
#
# TELNYX_CONNECTION_ID — Credentials-type SIP connection, used for the
#   browser's WebRTC registration and for minting per-user
#   telephony_credentials (lib/telnyx/provisioning.ts). This is the
#   connection id shown on Telnyx portal → Voice → Credentials.
#
# TELNYX_CALL_CONTROL_APP_ID — Call Control Application ID, used for
#   server-side call orchestration (dialing new outbound legs, blind
#   transfer via link_to + bridge_on_answer). This is the Application
#   ID shown on Telnyx portal → Call Control → Applications.
#   Passing the credential connection id here fails with
#   "The requested connection_id (Call Control App ID) is either
#   invalid or does not exist."
TELNYX_CONNECTION_ID=
TELNYX_CALL_CONTROL_APP_ID=

# Legacy shared SIP credentials — kept only for emergency rollback of
# the per-user credential migration. Do NOT remove.
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ENCRYPTION_KEY=         # Random 32+ bytes; encrypts per-user SIP passwords

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# App
NEXT_PUBLIC_APP_NAME=Ava Softphone
NEXT_PUBLIC_APP_URL=             # Base URL, used by webhook → /api/ai/* fan-out
